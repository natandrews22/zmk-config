/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp N7 &kp N8 &kp N9
                &kp N4 &kp N5 &kp N6
                &kp N1 &kp N2 &kp N3
                &kp N0 &kp DOT &to 1
            >;
        };

        layer1 {
            bindings = <
                &kp A &kp B &kp C
                &kp D &kp E &kp F
                &kp G &kp H &kp I
                &kp J &kp K &to 0
            >;
        };
    };
};